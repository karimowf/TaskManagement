@model TaskManagement.ViewModels.TaskListViewModel

@{
    ViewData["Title"] = "All Tasks";

    string NextOrder(string column)
    {
        if (Model.SortBy == column)
            return Model.SortOrder == "asc" ? "desc" : "asc";
        return "asc";
    }

    string SortIcon(string column)
    {
        if (Model.SortBy != column) return "bi-chevron-expand";
        return Model.SortOrder == "asc" ? "bi-chevron-up" : "bi-chevron-down";
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-list-task me-2"></i>Tasks</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Task
    </a>
</div>

@if (!Model.Tasks.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No tasks yet. <a asp-action="Create">Create one!</a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>
                            <a asp-action="Index"
                               asp-route-sortBy="priority"
                               asp-route-sortOrder="@NextOrder("priority")"
                               class="text-white text-decoration-none d-flex align-items-center gap-1">
                                Priority <i class="bi @SortIcon("priority")"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index"
                               asp-route-sortBy="deadline"
                               asp-route-sortOrder="@NextOrder("deadline")"
                               class="text-white text-decoration-none d-flex align-items-center gap-1">
                                Deadline <i class="bi @SortIcon("deadline")"></i>
                            </a>
                        </th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        @await Html.PartialAsync("_TaskRow", task)
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>Delete Task
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete <strong id="modalTaskTitle"></strong>?
                This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const taskId = button.getAttribute('data-task-id');
            const taskTitle = button.getAttribute('data-task-title');
            document.getElementById('modalTaskTitle').textContent = taskTitle;
            document.getElementById('deleteForm').action = '/Task/Delete/' + taskId;
        });
    </script>
}
