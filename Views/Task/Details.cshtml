@model TaskManagement.ViewModels.TaskViewModel

@{
    ViewData["Title"] = "Task Details";

    var statusBadgeClass = Model.Status switch
    {
        TaskManagement.Enums.TaskStatus.Active  => "bg-primary",
        TaskManagement.Enums.TaskStatus.Urgent  => "bg-warning text-dark",
        TaskManagement.Enums.TaskStatus.Overdue => "bg-danger",
        TaskManagement.Enums.TaskStatus.Done    => "bg-success",
        _ => "bg-secondary"
    };

    var priorityBadge = Model.Priority switch
    {
        TaskManagement.Enums.Priority.Low    => "bg-secondary",
        TaskManagement.Enums.Priority.Medium => "bg-warning text-dark",
        TaskManagement.Enums.Priority.High   => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-card-text me-2"></i>Task Details</h5>
                <span class="badge @statusBadgeClass fs-6">@Model.Status</span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Title</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Title</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">
                        @if (string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <span class="text-muted fst-italic">No description provided.</span>
                        }
                        else
                        {
                            @Model.Description
                        }
                    </dd>

                    <dt class="col-sm-4">Priority</dt>
                    <dd class="col-sm-8">
                        <span class="badge @priorityBadge">@Model.Priority</span>
                    </dd>

                    <dt class="col-sm-4">Deadline</dt>
                    <dd class="col-sm-8">
                        @if (Model.Deadline.HasValue)
                        {
                            @Model.Deadline.Value.ToString("dd MMMM yyyy, HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Completed</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsCompleted)
                        {
                            <i class="bi bi-check-circle-fill text-success fs-5"></i>
                        }
                        else
                        {
                            <i class="bi bi-circle text-secondary fs-5"></i>
                        }
                    </dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge @statusBadgeClass">@Model.Status</span>
                        <small class="text-muted ms-2">(computed at runtime)</small>
                    </dd>
                </dl>

                <hr />
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
